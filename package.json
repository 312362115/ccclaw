{
  "name": "ccclaw",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ccclaw/server dev",
    "build": "pnpm -r build",
    "migrate": "pnpm --filter @ccclaw/server migrate",
    "seed": "pnpm --filter @ccclaw/server seed",
    "lint": "eslint packages/*/src",
    "typecheck": "pnpm -r typecheck",
    "e2e": "node scripts/e2e-all.mjs",
    "e2e:quick": "node scripts/e2e-all.mjs --quick",
    "postinstall": "npm_config_build_from_source=true pnpm rebuild node-pty || true"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
