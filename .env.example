# 数据库方言：sqlite（低配快速验证） | postgresql（生产推荐） | mysql（企业内网）
DB_DIALECT=sqlite
# PostgreSQL / MySQL 模式必填，SQLite 模式忽略
DATABASE_URL=postgresql://ccclaw:ccclaw@localhost:5432/ccclaw
JWT_SECRET=change-me-to-a-random-string
ENCRYPTION_KEY=change-me-to-a-64-char-hex-string-representing-32-bytes-aes256xx
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
DATA_DIR=/data/ccclaw
PORT=3000
# Runner 认证密钥（最少 16 字符，不填则自动生成）
RUNNER_SECRET=change-me-to-a-random-string-16
# Feishu/Lark 机器人（可选，不填则禁用飞书渠道）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_DEFAULT_WORKSPACE_ID=
# FEISHU_DEFAULT_USER_ID=
# 定时任务全局并发数
SCHEDULER_CONCURRENCY=3
# 每用户最多定时任务数
MAX_TASKS_PER_USER=10
# 用户需在 Web 界面「个人设置 → Provider」中配置自己的 API Key
